{
  "name": "eslint-plugin-react-codemod",
  "description": "React specific codemod with ESLint's ability of autofix",
  "homepage": "https://github.com/Ryo98-SL/eslint-plugin-react-codemod",
  "author": "Ryo98-SL",
  "license": "MIT",
  "type": "module",
  "version": "0.1.1",
  "private": false,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "bun run /src/lint.ts",
    "build": "bun run /scripts/bun-build.ts",
    "prepare": "husky",
    "prepublishOnly": "npm test"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "helpers",
    "rules/*"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "devDependencies": {
    "@mui/material": "^7.1.0",
    "@rslib/core": "^0.12.4",
    "@types/bun": "latest",
    "@types/estree": "^1.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/scope-manager": "^8.58.0",
    "bun": "^1.2.11",
    "bun-plugin-dts": "^0.4.0",
    "fs-extra": "^11.3.1",
    "glob": "^11.0.3",
    "husky": "^9.1.7",
    "pkg-up": "^5.0.0",
    "react": "^19.1.0",
    "tsx": "^4.19.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0"
  },
  "packageManager": "bun@1.2.11",
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "@typescript-eslint/rule-tester": "^8.27.0",
    "@typescript-eslint/utils": "^8.39.0",
    "typescript-eslint": "^8.27.0",
    "@typescript-eslint/typescript-estree": "^8.39.0"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "eslint-plugin-react",
    "react-codemod",
    "auto-create-hook"
  ]
}
